{
  "name": "minimal-mcq-quiz",
  "version": "0.1.0",
  "private": true,
  "description": "Native shell for the hosted MCQ quiz application.",
  "main": "electron/main.js",
  "scripts": {
    "build:linux": "electron-builder --linux AppImage",
    "build:mac": "electron-builder --mac dmg",
    "build:win": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.quizapplication.mcq",
    "productName": "MCQ Quiz",
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "linux": {
      "category": "Education"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "category": "public.app-category.education"
    }
  }
}
